# --- Kimi (agent reasoning — the hot path) ---
KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODEL=kimi-k2.6

# --- Terminal 3 (verified identity + attributable settlement receipt) ---
# Developer key from the Terminal 3 claim page (an Ethereum private key used as
# the SIWE authenticator — keep secret). Identity + DID happen via the Node
# sidecar in agentdeal/integrations/terminal3_node (run `npm install` there).
TERMINAL3_API_KEY=
TERMINAL3_ENV=testnet

# --- Bright Data (real market reference price) ---
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=

# --- Daytona (sandboxed fulfillment) ---
DAYTONA_API_KEY=
DAYTONA_BASE_URL=

# --- TokenRouter (route seller agents to different models) ---
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.io
